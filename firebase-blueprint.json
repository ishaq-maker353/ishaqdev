{
  "entities": {
    "orders": {
      "title": "Client Orders & Hire Requests",
      "description": "Orders submitted by logged-in users or clients buying plans / hiring developer",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "userPhone": { "type": "string" },
        "planName": { "type": "string" },
        "price": { "type": "string" },
        "bkashTransaction": { "type": "string" },
        "projectRequirements": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "completed", "cancelled"] },
        "createdAt": { "type": "string" }
      },
      "required": ["userName", "userEmail", "planName", "price", "createdAt"]
    },
    "messages": {
      "title": "Contact Messages",
      "description": "Direct contact inquiries and message submissions",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" },
        "read": { "type": "boolean" }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "projects": {
      "title": "Portfolio Projects",
      "description": "Showcased web development projects",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "demoUrl": { "type": "string" },
        "githubUrl": { "type": "string" },
        "featured": { "type": "boolean" }
      },
      "required": ["title", "category", "description"]
    },
    "testimonials": {
      "title": "Client Reviews",
      "description": "Client testimonials and reviews",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "company": { "type": "string" },
        "avatar": { "type": "string" },
        "text": { "type": "string" },
        "rating": { "type": "number" },
        "date": { "type": "string" },
        "verified": { "type": "boolean" }
      },
      "required": ["name", "text", "rating"]
    },
    "plans": {
      "title": "Pricing Packages",
      "description": "Available hiring plans and service packages",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "string" },
        "duration": { "type": "string" },
        "description": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "popular": { "type": "boolean" },
        "bkashNumber": { "type": "string" }
      },
      "required": ["name", "price", "duration"]
    }
  }
}
